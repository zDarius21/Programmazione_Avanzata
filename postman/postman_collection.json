{
  "info": {
    "name": "Programmazione Avanzata",
    "_postman_id": "collection-programmazione-avanzata",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "item": [
            {
              "name": "RegisterSuccess",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code 201', () => pm.response.to.have.status(201));",
                      "pm.test('success true', () => {",
                      "  const body = pm.response.json();",
                      "  pm.expect(body.success).to.be.true;",
                      "  pm.expect(body.data.token).to.be.a('string');",
                      "  pm.environment.set('JWT_TOKEN', body.data.token);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"utente@test.com\",\n  \"password\": \"Password123!\"\n}"
                },
                "url": {
                  "raw": "http://{{HOST}}:{{PORT}}/auth/register",
                  "protocol": "http",
                  "host": ["{{HOST}}"],
                  "port": "{{PORT}}",
                  "path": ["auth", "register"]
                }
              }
            },
            {
              "name": "RegisterMissingFields",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code 400', () => pm.response.to.have.status(400));",
                      "pm.test('success false', () => {",
                      "  const body = pm.response.json();",
                      "  pm.expect(body.success).to.be.false;",
                      "  pm.expect(body.error).to.be.a('string');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
